## OS specific
##
NIX_ROOT=/nix
if [ -d "$NIX_ROOT" ]
then
  NIX_PROFILE_DEFAULT=$NIX_ROOT/var/nix/profiles/default
  NIX_PROFILE_USER=~/.nix-profile
  PATH=$NIX_PROFILE_USER/bin:$NIX_PROFILE_DEFAULT/bin:$PATH
  SHARE=$NIX_PROFILE_USER/share
else
  case $OSTYPE in
    darwin*)
      if [ "$(arch)" = "arm64" ]
      then
        HOMEBREW=/opt/homebrew
      else
        HOMEBREW=/usr/local
      fi
      HOMEHOMEBREW_TEMP=/tmp/hb
      ;;
    linux*)
      HOMEBREW=/home/linuxbrew/.linuxbrew
      [ -d /snap ] && PATH=/snap/bin:$PATH
      ;;
    freebsd*)
    ;;
  esac

  if [ -d "$HOMEBREW" ]
  then
    PATH=$HOMEBREW/bin:$HOMEBREW/sbin:$PATH
    SHARE=$HOMEBREW/share
  else
    echo "Homebrew not found ):"
  fi
fi

