## Functions
##
function _exists() {
  if which "$1" &> /dev/null; then
    return `true`
  else
    return `false`
  fi
}

function _completions() {
  _exists "$1" || return

  cmd=$1
  args=$2
  dashes=$3
  shell=$(basename $SHELL)

  case $shell in
    "bash")
      eval "$($cmd $args $dashes$shell)"
    ;;
    "zsh")
      source <($cmd $args $dashes$shell)
    ;;
    *)
    ;;
  esac
}
 
function _alias() {
  cmd=$1; shift
  alias=$1; shift
  if _exists $alias; then
    echo "$alias $@"
  else
    echo "$cmd"
  fi
}

